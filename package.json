{
  "name": "react-use-scroll-sync",
  "version": "0.1.6",
  "description": "React hook for synchronizing scroll position across multiple elements.",
  "author": "gk4m",
  "license": "MIT",
  "homepage": "https://github.com/gk4m/react-use-scroll-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gk4m/react-use-scroll-sync.git"
  },
  "bugs": {
    "url": "https://github.com/gk4m/react-use-scroll-sync/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "typescript",
    "dom",
    "scroll",
    "scrolling",
    "sync",
    "synchronization"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "lint": "tsc --noEmit",
    "prepare": "npm run build",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "jsdom": "^26.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.9"
  }
}
