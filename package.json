{
  "name": "react-use-scroll-sync",
  "version": "0.1.6",
  "description": "React hook for synchronizing scroll position across multiple elements.",
  "author": "gk4m",
  "license": "MIT",
  "homepage": "https://github.com/gk4m/react-use-scroll-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gk4m/react-use-scroll-sync.git"
  },
  "bugs": {
    "url": "https://github.com/gk4m/react-use-scroll-sync/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "react-hooks",
    "hooks",
    "typescript",
    "dom",
    "scroll",
    "scrolling",
    "sync",
    "synchronization"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "bootstrap": "yarn install && yarn --cwd example install",
    "demo:build": "yarn --cwd example build",
    "demo:dev": "yarn --cwd example dev",
    "demo:preview": "yarn --cwd example preview",
    "dev": "yarn demo:dev",
    "lint": "tsc --noEmit",
    "prepare": "yarn build",
    "test": "vitest run --environment jsdom",
    "test:watch": "vitest --environment jsdom",
    "verify": "yarn lint && yarn test && yarn build && yarn demo:build"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
